<odoo>
    <data>
        <!-- Form View for Student -->
        <record id="view_student_student_form" model="ir.ui.view">
            <field name="name">student.student.form</field>
            <field name="model">student.student</field>
            <field name="arch" type="xml">
                <form string="Student">
                    <header>
                        <button name="demo_orm_operations" type="object" string="Run ORM Demo" class="oe_highlight" help="Click to test create, search, write, and unlink methods in the logs"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="enrollment_no"/>
                            </group>
                            <group>
                                <field name="email"/>
                                <field name="course_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View for Student -->
        <record id="view_student_student_tree" model="ir.ui.view">
            <field name="name">student.student.tree</field>
            <field name="model">student.student</field>
            <field name="arch" type="xml">
                <tree string="Students">
                    <field name="name"/>
                    <field name="enrollment_no"/>
                    <field name="course_id"/>
                </tree>
            </field>
        </record>

        <!-- Action for Student -->
        <record id="action_student_student" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">student.student</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
