<odoo>
    <data>
        <!-- Form View for Course -->
        <record id="view_student_course_form" model="ir.ui.view">
            <field name="name">student.course.form</field>
            <field name="model">student.course</field>
            <field name="arch" type="xml">
                <form string="Course">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View for Course -->
        <record id="view_student_course_tree" model="ir.ui.view">
            <field name="name">student.course.tree</field>
            <field name="model">student.course</field>
            <field name="arch" type="xml">
                <tree string="Courses">
                    <field name="name"/>
                    <field name="code"/>
                </tree>
            </field>
        </record>

        <!-- Action for Course -->
        <record id="action_student_course" model="ir.actions.act_window">
            <field name="name">Courses</field>
            <field name="res_model">student.course</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
